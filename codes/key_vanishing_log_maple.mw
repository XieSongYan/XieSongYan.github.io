<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">## EXPAND ALL UNKNOWNS UP TO y^(15*d)

for l from 0 to m - 0*3 do 
AA||l := add(add(A||l[i,j]*x^i*y^j, i=0..dA[l]-j), j=0..min(dA[l],15*d-1)): od:

for l from 0 to m - 1*3 do
BB||l := add(add(B||l[i,j]*x^i*y^j, i=0..dB[l]-j), j=0..min(dB[l],15*d-1)): od:

for l from 0 to m - 2*3 do
CC||l := add(add(C||l[i,j]*x^i*y^j, i=0..dC[l]-j), j=0..min(dC[l],15*d-1)): od:

for l from 0 to m - 3*3 do
DD||l := add(add(D||l[i,j]*x^i*y^j, i=0..dD[l]-j), j=0..min(dD[l],15*d-1)): od:

for l from 0 to m - 4*3 do
EE||l := add(add(E||l[i,j]*x^i*y^j, i=0..dE[l]-j), j=0..min(dE[l],15*d-1)): od;

for l from 0 to m - 5*3 do
FF||l := add(add(F||l[i,j]*x^i*y^j, i=0..dF[l]-j), j=0..min(dF[l],15*d-1)): od:

for l from 0 to m - 6*3 do:
GG||l := add(add(G||l[i,j]*x^i*y^j, i=0..dG[l]-j), j=0..min(dG[l],15*d-1)): od:

for l from 0 to m - 7*3 do
HH||l := add(add(H||l[i,j]*x^i*y^j, i=0..dH[l]-j), j=0..min(dH[l],15*d-1)): od:

## SYSTEM FOR DIVISIBILITY BY y^(15*d)

Systemey15d := {}:

for k from 0 to (m-15)/3   do

Coeffs_y15d[15,m-15-3*k,k] := {coeffs(expand(mtaylor(Eq[15,m-15-3*k,k], y, 15*d)), [x,y])}:

Systemey15d := Systemey15d union Coeffs_y15d[15,m-15-3*k,k]:

od:

Systeme_y15d := Systemey15d:

## VARIABLES FOR DIVISIBILITY BY y^(15*d)

Variables_y15d := indets(Systeme_y15d):

## RESOLUTION y^(15*d)

Solutions_y15d := solve(Systeme_y15d, Variables_y15d):

assign(Solutions_y15d):

##

for l from 0 to m - 0*3 do nops(expand(AA||l)) od;
for l from 0 to m - 1*3 do nops(expand(BB||l)) od;
for l from 0 to m - 2*3 do nops(expand(CC||l)) od;
for l from 0 to m - 3*3 do nops(expand(DD||l)) od;
for l from 0 to m - 4*3 do nops(expand(EE||l)) od;
for l from 0 to m - 5*3 do nops(expand(FF||l)) od;
for l from 0 to m - 6*3 do nops(expand(GG||l)) od;
for l from 0 to m - 7*3 do nops(expand(HH||l)) od;
</Text-field>
</Input>
